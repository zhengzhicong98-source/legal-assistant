{
  "name": "miaoda-taro-react-starter",
  "version": "1.0.0",
  "description": "开箱即用的基于Taro + React + Zustand + TailwindCSS + TypeScript的模板",
  "author": "miaoda-team",
  "license": "MIT",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "sass"
  },
  "scripts": {
    "dev": "echo '[error] dev requires a real Taro runtime. Use dev:weapp inside WeChat DevTools or dev:h5 for browser.' && exit 1",
    "dev:h5": "taro build --type h5 --watch",
    "dev:weapp": "taro build --type weapp --watch",
    "build": "echo '[error] build requires a real Taro runtime. Use build:weapp or build:h5.' && exit 1",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "build:weapp": "taro build --type weapp",
    "build:h5": "taro build --type h5",
    "postinstall": "weapp-tw patch",
    "lint": "./scripts/runLint.sh",
    "seed": "node scripts/seed-knowledge.mjs",
    "seed:dry-run": "node scripts/seed-knowledge.mjs --dry-run",
    "eval:rag": "node scripts/eval-rag.mjs"
  },
  "browserslist": [
    "last 5 years",
    "Android >= 9",
    "iOS >= 13",
    "not dead"
  ],
  "dependencies": {
    "@babel/runtime": "^7.28.6",
    "@supabase/supabase-js": "2.103.1",
    "@tarojs/components": "4.1.10",
    "@tarojs/helper": "4.1.10",
    "@tarojs/plugin-framework-react": "4.1.10",
    "@tarojs/plugin-generator": "4.1.10",
    "@tarojs/plugin-http": "4.1.10",
    "@tarojs/plugin-platform-h5": "4.1.10",
    "@tarojs/plugin-platform-weapp": "4.1.10",
    "@tarojs/react": "4.1.10",
    "@tarojs/runtime": "4.1.10",
    "@tarojs/shared": "4.1.10",
    "@tarojs/taro": "4.1.10",
    "immer": "^11.1.3",
    "miaoda-sc-plugin": "1.0.61",
    "miaoda-taro-utils": "0.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "supabase-wechat-js": "0.1.1",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@babel/core": "^7.28.6",
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@babel/plugin-transform-class-properties": "^7.28.6",
    "@babel/plugin-transform-private-methods": "^7.28.6",
    "@babel/preset-react": "^7.28.5",
    "@biomejs/biome": "2.4.5",
    "@egoist/tailwindcss-icons": "^1.9.0",
    "@iconify-json/lucide": "^1.2.86",
    "@iconify-json/mdi": "^1.2.3",
    "@playwright/test": "^1.61.0",
    "@tarojs/cli": "4.1.10",
    "@tarojs/taro-loader": "4.1.10",
    "@tarojs/vite-runner": "4.1.10",
    "@types/bun": "^1.3.10",
    "@types/eslint": "^9.6.1",
    "@types/estree": "^1.0.8",
    "@types/node": "^24.3.0",
    "@types/react": "^18.3.24",
    "@typescript/native-preview": "7.0.0-dev.20260303.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "1.6.0",
    "autoprefixer": "^10.5.0",
    "babel-preset-taro": "4.1.10",
    "happy-dom": "^20.10.6",
    "miaoda-taro-plugin-html": "4.1.10-2",
    "oxc-parser": "^0.116.0",
    "oxc-resolver": "^11.19.1",
    "oxlint": "^1.51.0",
    "pg": "^8.22.0",
    "picocolors": "^1.1.1",
    "postcss": "^8.5.6",
    "react-refresh": "^0.18.0",
    "sass": "^1.98.0",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^4.5.14",
    "vitest": "1.6.0",
    "weapp-tailwindcss": "^4.9.4"
  },
  "resolutions": {
    "esbuild": "0.21.5"
  },
  "packageManager": "pnpm@10.30.3"
}