# Supabase 项目配置
TARO_APP_SUPABASE_URL=https://your-project.supabase.co
TARO_APP_SUPABASE_ANON_KEY=your-anon-key

# 微信小程序 AppID
TARO_APP_APP_ID=your-wechat-app-id

# 以下密钥请在 Supabase Dashboard → Edge Functions Secrets 中配置，不要放在前端代码中
# INTEGRATIONS_API_KEY=your-zhipuai-api-key     # 智谱 AI
# AMAP_KEY=your-amap-webapi-key                  # 高德地图
